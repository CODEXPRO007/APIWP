# ================================
# CortexHost WhatsApp Bridge - ENV
# ================================

# Port for the bridge server (dashboard + API)
PORT=4040

# Secret key WHMCS must send in "x-api-key" header when calling /api/send
# Generate a strong random string, keep it secret.
API_SECRET=change_this_to_a_long_random_string

# Dashboard login password (admin panel to view QR / logs / settings)
ADMIN_PASSWORD=change_this_password

# Session encryption secret
SESSION_SECRET=change_this_session_secret_too

# Default country code used if a number is sent without one (e.g. 91 for India)
DEFAULT_COUNTRY_CODE=91
